# -----------------------------------------------
# Where all client site folders live on your machine
# Use a WSL path — NOT /mnt/c/...
# -----------------------------------------------
SITES_PATH=/home/yourname/wp-sites

# -----------------------------------------------
# SSH key used to connect to remote servers
# -----------------------------------------------
SSH_KEY_PATH=/home/yourname/.ssh/wp_local_manager

# -----------------------------------------------
# Sites config files
#
# Single workspace (default):
#   SITES_FILE points to one JSON file.
#   If omitted, defaults to sites.json in the repo root.
#
# Multiple workspaces (freelance + agency job, etc.):
#   Use SITES_FILES with a comma-separated list.
#   Each file becomes a named workspace in the UI.
#   Name is derived from the filename:
#     sites.freelance.json  →  "freelance"
#     sites.agency.json     →  "agency"
#
# Only set one of the two — SITES_FILES takes precedence.
# -----------------------------------------------
SITES_FILE=/home/yourname/wp-local-manager/sites.json
# SITES_FILES=/home/yourname/wp-local-manager/sites.freelance.json,/home/yourname/wp-local-manager/sites.agency.json

# -----------------------------------------------
# Active sites (managed automatically — don't edit manually)
# Comma-separated list of currently running DDEV site slugs
# -----------------------------------------------
ACTIVE_SITES=

# -----------------------------------------------
# UI port (default 3000)
# -----------------------------------------------
UI_PORT=3000

# -----------------------------------------------
# R2 / S3 uploads fallback URL (optional)
# Set this if client sites use Cloudflare R2 or S3 for media offload.
# Uploads will be skipped during rsync and served from this URL instead.
# -----------------------------------------------
R2_BUCKET_URL=

# -----------------------------------------------
# WHM API (optional — reserved for future use)
# -----------------------------------------------
WHM_HOST=
WHM_USER=
WHM_API_TOKEN=