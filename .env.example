# -----------------------------------------------
# Where all client site folders live on your machine
# Use a path inside WSL, NOT /mnt/c/...
# -----------------------------------------------
SITES_PATH=/home/yourname/wp-sites

# -----------------------------------------------
# SSH key used to connect to remote servers and GitHub
# -----------------------------------------------
SSH_KEY_PATH=/home/yourname/.ssh/wp_local_manager

# -----------------------------------------------
# Active site (managed by swap-site.sh — don't edit manually)
# -----------------------------------------------
ACTIVE_SITES=

# -----------------------------------------------
# UI port (default 3000)
# -----------------------------------------------
UI_PORT=3000

# -----------------------------------------------
# R2 / S3 uploads fallback URL (optional)
# Set this if using Cloudflare R2 offload
# -----------------------------------------------
R2_BUCKET_URL=

# -----------------------------------------------
# WHM API (optional — future auto-discovery)
# -----------------------------------------------
WHM_HOST=
WHM_USER=
WHM_API_TOKEN=